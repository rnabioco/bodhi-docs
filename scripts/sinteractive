#!/bin/bash
# -*- coding: utf-8 -*-
#
# sinteractive — start an interactive shell on a Slurm compute node.
#
# Submits a batch job that launches a detached tmux session on the
# allocated node, then SSHes in and attaches to it. Because the shell
# lives in tmux, the session survives SSH drops and can be reattached
# later (see --attach / --list).
#
# Clean-room reimplementation, inspired by the original sinteractive by
# Pär Andersson (NSC, Sweden) and the later CU Boulder adaptation by
# Jonathon Anderson. Maintained by Jay Hesselberth.

# Treat unset variables as errors; the argument handling below guards every
# optional value explicitly, so this only fires on genuine bugs.
set -u

TMUX_BIN='/usr/local/bin/tmux'
JOB_ID=''

# Convert time shorthand (e.g. 8h, 30m, 2d, 1d12h, 1h30m) to HH:MM:SS
function parse_time {
  local input="$1"

  # Already in SLURM format (contains : or D-), pass through
  if [[ "$input" =~ [:] ]] || [[ "$input" =~ ^[0-9]+- ]]; then
    echo "$input"
    return
  fi

  # Pure integer = minutes (SLURM native)
  if [[ "$input" =~ ^[0-9]+$ ]]; then
    echo "$input"
    return
  fi

  local days=0 hours=0 minutes=0
  local remaining="$input"

  if [[ "$remaining" =~ ^([0-9]+)d ]]; then
    days="${BASH_REMATCH[1]}"
    remaining="${remaining#*d}"
  fi
  if [[ "$remaining" =~ ^([0-9]+)h ]]; then
    hours="${BASH_REMATCH[1]}"
    remaining="${remaining#*h}"
  fi
  if [[ "$remaining" =~ ^([0-9]+)m ]]; then
    minutes="${BASH_REMATCH[1]}"
    remaining="${remaining#*m}"
  fi

  if [[ -n "$remaining" ]]; then
    echo 1>&2 "Warning: unrecognized time format '$input', passing through to SLURM"
    echo "$input"
    return
  fi

  # Normalize carries so e.g. 90m -> 1h30m and 25h -> 1d1h, keeping each
  # field within range for SLURM's [D-]HH:MM:SS format.
  hours=$((hours + minutes / 60))
  minutes=$((minutes % 60))
  days=$((days + hours / 24))
  hours=$((hours % 24))

  if ((days > 0)); then
    printf '%d-%02d:%02d:00\n' "$days" "$hours" "$minutes"
  else
    printf '%02d:%02d:00\n' "$hours" "$minutes"
  fi
}

function usage {
  cat <<EOF
Usage: sinteractive [OPTIONS] [-- SBATCH_ARGS...]
       sinteractive --attach JOBID|NAME

Start an interactive tmux session on a compute node via Slurm.
The session survives SSH drops; reconnect with --attach.

Options:
  -n, --name NAME       Name the session for easy reattach
  --time TIME           Wall time limit (default: 1 day; e.g. 8h, 30m, 1d12h)
  -j, --threads N       Number of CPUs (default: 2)
  -m SIZE               Memory (default: 8G; e.g. 16G)
  -a, --attach TARGET   Reattach to a running session by JOBID or NAME
  -l, --list            List your running sessions
  -h, --help            Show this help message

Unrecognized options pass through to sbatch (e.g. --partition, --gres).

Examples:
  sinteractive                          # 1-day session, 2 CPUs, 8G memory
  sinteractive -n myproj --time=8h      # named 8-hour session
  sinteractive --attach myproj          # reconnect after a disconnect

Inside the session, Ctrl-b h opens a help popup; Ctrl-b d detaches
(the job keeps running).

Full documentation, including --detach/--status/--json for scripting,
--node, --mouse, and SINTERACTIVE_* environment variables:

  man sinteractive
EOF
  exit 0
}

function main {
  if [[ "${1:-}" == 'tmux' ]]; then
    shift
    start_tmux "$@"
    return
  elif [[ "${1:-}" == 'attach' ]]; then
    shift
    attach_tmux "$@"
    return
  elif [[ "${1:-}" == 'help-popup' ]]; then
    shift
    show_help_popup "$@"
    return
  elif [[ "${1:-}" == 'rename-session' ]]; then
    shift
    rename_session "$@"
    return
  fi

  # Parse custom flags before passing remaining args to sbatch
  local args=()
  local reattach_target=''
  local session_name=''
  local enable_mouse=0
  local detach_mode=0
  local json_out=0
  local do_list=0
  local do_status=0
  local status_target=''
  case "${SINTERACTIVE_MOUSE:-}" in
  on | 1 | true | yes) enable_mouse=1 ;;
  esac
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      usage
      ;;
    --mouse)
      enable_mouse=1
      shift
      ;;
    --no-mouse)
      enable_mouse=0
      shift
      ;;
    --detach)
      detach_mode=1
      shift
      ;;
    --json)
      json_out=1
      shift
      ;;
    --status)
      do_status=1
      if [[ -n "${2:-}" && "$2" != -* ]]; then
        status_target="$2"
        shift 2
      else
        shift
      fi
      ;;
    --status=*)
      do_status=1
      status_target="${1#--status=}"
      shift
      ;;
    -l | --list)
      do_list=1
      shift
      ;;
    -a | --attach)
      if [[ -z "${2:-}" || "$2" == -* ]]; then
        echo 1>&2 "Error: $1 requires a JOBID or NAME argument."
        echo 1>&2 "Run 'sinteractive --list' to see available sessions."
        exit 1
      fi
      reattach_target="$2"
      shift 2
      ;;
    --attach=*)
      reattach_target="${1#--attach=}"
      if [[ -z "${reattach_target}" ]]; then
        echo 1>&2 "Error: --attach requires a JOBID or NAME argument."
        echo 1>&2 "Run 'sinteractive --list' to see available sessions."
        exit 1
      fi
      shift
      ;;
    -n | --name)
      [[ $# -ge 2 ]] || {
        echo 1>&2 "Error: $1 requires a NAME argument."
        exit 1
      }
      session_name="$2"
      shift 2
      ;;
    --name=*)
      session_name="${1#--name=}"
      shift
      ;;
    --node)
      [[ $# -ge 2 ]] || {
        echo 1>&2 "Error: --node requires a NODE argument."
        exit 1
      }
      args+=(--nodelist="$2")
      shift 2
      ;;
    --node=*)
      args+=(--nodelist="${1#--node=}")
      shift
      ;;
    --time)
      [[ $# -ge 2 ]] || {
        echo 1>&2 "Error: --time requires a TIME argument."
        exit 1
      }
      args+=(--time="$(parse_time "$2")")
      shift 2
      ;;
    --time=*)
      args+=(--time="$(parse_time "${1#--time=}")")
      shift
      ;;
    -t)
      [[ $# -ge 2 ]] || {
        echo 1>&2 "Error: -t requires a TIME argument."
        exit 1
      }
      args+=(-t "$(parse_time "$2")")
      shift 2
      ;;
    --partition)
      [[ $# -ge 2 ]] || {
        echo 1>&2 "Error: --partition requires a PARTITION argument."
        exit 1
      }
      args+=(--partition="$2")
      shift 2
      ;;
    --partition=*)
      args+=(--partition="${1#--partition=}")
      shift
      ;;
    -j | --threads)
      [[ $# -ge 2 ]] || {
        echo 1>&2 "Error: $1 requires a CPU-count argument."
        exit 1
      }
      args+=(--cpus-per-task="$2")
      shift 2
      ;;
    --threads=*)
      args+=(--cpus-per-task="${1#--threads=}")
      shift
      ;;
    -m)
      [[ $# -ge 2 ]] || {
        echo 1>&2 "Error: -m requires a SIZE argument."
        exit 1
      }
      args+=(--mem="$2")
      shift 2
      ;;
    *)
      args+=("$1")
      shift
      ;;
    esac
  done

  # Informational commands; both exit. Run after flag parsing so they can be
  # combined with --json in any order, and before the nesting guard so they
  # work from inside a session.
  if ((do_list)); then
    list_sessions "$json_out"
  fi
  if ((do_status)); then
    show_status "$status_target" "$json_out"
  fi

  # Don't allow attaching (or an attaching launch) from inside an existing
  # session — both would nest tmux. A --detach launch never attaches, so it
  # is allowed from within a session.
  if [[ -n "${TMUX:-}" ]] && [[ "$TMUX" == *sinteractive* ]] &&
    { ((!detach_mode)) || [[ -n "${reattach_target}" ]]; }; then
    echo 1>&2 "Error: Already inside an sinteractive session. Exit this session first."
    exit 1
  fi

  if [[ -n "${reattach_target}" ]]; then
    reattach "${reattach_target}"
  fi

  if [[ -n "${session_name}" ]]; then
    if ! [[ "${session_name}" =~ ^[A-Za-z0-9._-]+$ ]]; then
      echo 1>&2 "Error: --name must contain only letters, digits, '.', '_', '-'"
      exit 1
    fi
    # Best-effort duplicate-name guard: the Comment marker that records the
    # name is only set after submission (see below), so two near-simultaneous
    # launches with the same name can both pass here. Reattach-by-name
    # resolves the resulting ambiguity by erroring on multiple matches.
    local existing
    existing=$(squeue --me --states RUNNING,PENDING --noheader \
      --Format=JobID:12,Comment:80 2>/dev/null |
      awk -v n="sinteractive:${session_name}" '$2 == n {print $1}')
    if [[ -n "${existing}" ]]; then
      echo 1>&2 "Error: A sinteractive session named '${session_name}' is already running:"
      echo 1>&2 "  JobID(s): $(echo ${existing} | xargs)"
      echo 1>&2 "Pick a different name, or reattach with: sinteractive --attach ${session_name}"
      exit 1
    fi
  fi

  set -- "${args[@]}"

  # If a session name was given and the user did not pass --job-name/-J,
  # set it so the name shows up natively in squeue output.
  if [[ -n "${session_name}" ]] && ! printf '%s\n' "$@" | grep -qE '^(--job-name|-J)'; then
    set -- --job-name="sint-${session_name}" "$@"
  fi

  # Defaults below can be personalized with SINTERACTIVE_* environment
  # variables (e.g. in ~/.bashrc); explicit flags always win.

  # Default to 1 day if no --time/-t specified
  if ! printf '%s\n' "$@" | grep -qE '^(--time|-t)'; then
    set -- --time="$(parse_time "${SINTERACTIVE_TIME:-24:00:00}")" "$@"
  fi

  # Default to interactive partition if no --partition/-p specified
  if ! printf '%s\n' "$@" | grep -qE '^(--partition|-p)'; then
    set -- --partition="${SINTERACTIVE_PARTITION:-interactive}" "$@"
  fi

  # Default to 2 CPUs if no --cpus-per-task/-c specified
  if ! printf '%s\n' "$@" | grep -qE '^(--cpus-per-task|-c)'; then
    set -- --cpus-per-task="${SINTERACTIVE_CPUS:-2}" "$@"
  fi

  # Default to 8G memory if no --mem specified
  if ! printf '%s\n' "$@" | grep -qE '^--mem'; then
    set -- --mem="${SINTERACTIVE_MEM:-8G}" "$@"
  fi

  # Refuse to submit if --time would overlap an upcoming MAINT reservation
  if ! check_maintenance_window "$@"; then
    exit 1
  fi

  # Check interactive job limit before submitting
  local partition
  partition=$(get_partition_from_args "$@")

  if ! check_job_limit "$partition"; then
    exit 1
  fi

  # Feature flags to forward to the batch-side tmux setup (start_tmux).
  local tmux_args=()
  ((enable_mouse)) && tmux_args+=(--mouse)
  [[ -n "${session_name}" ]] && tmux_args+=(--session-name="${session_name}")

  local output
  local sbatch_ec
  output=$(sbatch --output=/dev/null --error=/dev/null "$@" "${BASH_SOURCE[0]}" tmux "${tmux_args[@]}")
  sbatch_ec=$?

  JOB_ID=$(grep -Eo -e '\b[0-9]+$' <<<"${output}")
  if [[ -z "${JOB_ID}" ]]; then
    echo 1>&2 "$0: unable to find job id in sbatch output"
    exit "$sbatch_ec"
  fi

  local job_comment="sinteractive"
  if [[ -n "${session_name}" ]]; then
    job_comment="sinteractive:${session_name}"
  fi
  scontrol update JobId="${JOB_ID}" Comment="${job_comment}"

  echo 1>&2 "Interactive job with ID ${JOB_ID} submitted, please wait."
  local state
  while true; do
    sleep 5s

    # Check job status
    state=$(squeue --jobs "${JOB_ID}" --states PENDING,RUNNING --noheader --Format state | xargs)
    if [[ "${state}" == 'RUNNING' ]]; then
      break
    elif [[ "${state}" != 'PENDING' ]]; then
      echo 1>&2 "$0: job is neither RUNNING nor PENDING. Aborting."
      scancel --quiet "${JOB_ID}"
      exit 1
    fi

    echo 1>&2 -n '.'
  done

  local batchhost
  batchhost=$(squeue --jobs "${JOB_ID}" --noheader --Format batchhost | xargs)

  echo 1>&2 ''
  echo 1>&2 'Connecting to sinteractive session, please wait...'

  # A RUNNING job only means the allocation exists; the batch script still
  # has to bring up the tmux server. Poll for the session (a single SSH that
  # retries on the node) instead of guessing a fixed sleep, which races on a
  # slow or loaded node.
  local sock="sinteractive-${JOB_ID}"
  local connected=0
  if ssh -o BatchMode=yes -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new \
    "${batchhost}" \
    "for i in \$(seq 1 30); do ${TMUX_BIN} -L '${sock}' has-session -t '${sock}' 2>/dev/null && exit 0; sleep 1; done; exit 1"; then
    connected=1
  fi

  # The session is up (or we gave up waiting); from this point a detach or
  # disconnect should NOT cancel the job.
  trap - SIGINT SIGTERM EXIT

  if ((connected == 0)); then
    echo 1>&2 ''
    echo 1>&2 "$0: tmux session did not come up on ${batchhost} within 30s."
    echo 1>&2 "Job ${JOB_ID} may still be starting. Reconnect with:"
    echo 1>&2 "  sinteractive --attach ${JOB_ID}"
    exit 1
  fi

  # Headless launch: report how to reach the session and return without
  # attaching (there may be no terminal to attach from). With --json the
  # status object is the whole output; show_status exits.
  if ((detach_mode)); then
    if ((json_out)); then
      show_status "${JOB_ID}" 1
    fi
    local attach_target="${session_name:-${JOB_ID}}"
    echo 1>&2 ''
    echo 1>&2 "Session ${JOB_ID} is ready on ${batchhost}."
    echo 1>&2 ''
    echo 1>&2 "  Attach:   sinteractive --attach ${attach_target}"
    echo 1>&2 "  Status:   sinteractive --status ${attach_target}"
    echo 1>&2 "  Run cmd:  srun --overlap --jobid=${JOB_ID} -- <command>"
    echo 1>&2 "  Cancel:   scancel ${JOB_ID}"
    return
  fi

  ssh -X -t "${batchhost}" "${BASH_SOURCE[0]}" attach "sinteractive-${JOB_ID}"

  # Give the batch script a moment to finish shutting down
  sleep 3

  # Check if the sinteractive job is still running after SSH exits
  local post_state
  post_state=$(squeue --jobs "${JOB_ID}" --states RUNNING --noheader --Format state 2>/dev/null | xargs)

  if [[ "${post_state}" == 'RUNNING' ]]; then
    echo 1>&2 ''
    echo 1>&2 "Disconnected from sinteractive session."
    echo 1>&2 "Your job ${JOB_ID} is still running on ${batchhost}."
    echo 1>&2 ''
    local attach_target="${JOB_ID}"
    if [[ -n "${session_name}" ]]; then
      attach_target="${session_name}"
    fi
    echo 1>&2 "To reconnect:"
    echo 1>&2 "  sinteractive --attach ${attach_target}"
    echo 1>&2 ''
    echo 1>&2 "To cancel the job:"
    echo 1>&2 "  scancel ${JOB_ID}"

    # Show other running sinteractive sessions
    local other_running
    other_running=$(squeue --me --states RUNNING --noheader \
      --Format=JobID:12,Comment:30,NodeList:16,TimeUsed:12,TimeLimit:12 2>/dev/null |
      grep sinteractive | grep -v "^${JOB_ID} ")

    if [[ -n "$other_running" ]]; then
      echo 1>&2 ''
      echo 1>&2 'Other running sinteractive sessions:'
      printf 1>&2 '  %-10s  %-14s  %-10s  %-10s\n' 'JOBID' 'NODE' 'ELAPSED' 'TIMELIMIT'
      while read -r jobid comment node elapsed limit; do
        printf 1>&2 '  %-10s  %-14s  %-10s  %-10s\n' "$jobid" "$node" "$elapsed" "$limit"
      done <<<"$other_running"
    fi
  else
    echo 1>&2 "Session ended. Job ${JOB_ID} is no longer running."

    # Show any remaining sinteractive sessions
    local remaining
    remaining=$(squeue --me --states RUNNING --noheader \
      --Format=JobID:12,Comment:30,NodeList:16,TimeUsed:12,TimeLimit:12 2>/dev/null |
      grep sinteractive)

    if [[ -n "$remaining" ]]; then
      echo 1>&2 ''
      echo 1>&2 'You have other sinteractive sessions still running:'
      printf 1>&2 '  %-10s  %-14s  %-10s  %-10s\n' 'JOBID' 'NODE' 'ELAPSED' 'TIMELIMIT'
      while read -r jobid comment node elapsed limit; do
        printf 1>&2 '  %-10s  %-14s  %-10s  %-10s\n' "$jobid" "$node" "$elapsed" "$limit"
      done <<<"$remaining"
      echo 1>&2 ''
      echo 1>&2 'To free slots, cancel sessions you no longer need:'
      while read -r jobid _rest; do
        echo 1>&2 "  scancel $jobid"
      done <<<"$remaining"
    fi
  fi
}

# JSON-encode a string, escaping backslashes and double quotes; an empty
# string encodes as null.
function json_string_or_null {
  local s=$1
  if [[ -z "$s" ]]; then
    printf 'null'
    return
  fi
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '"%s"' "$s"
}

# Query the current working directory of an sinteractive tmux session by
# asking tmux on the compute node. Returns empty string on failure.
function get_session_cwd {
  local node=$1 jobid=$2
  local sock="sinteractive-${jobid}"
  local session="sinteractive-${jobid}"
  local cwd
  cwd=$(ssh -o BatchMode=yes -o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new \
    "$node" \
    "$TMUX_BIN -L '$sock' display-message -p -t '$session' '#{pane_current_path}'" \
    2>/dev/null)
  # Collapse $HOME prefix to ~ for readability
  if [[ -n "$cwd" && "$cwd" == "$HOME"* ]]; then
    cwd="~${cwd#$HOME}"
  fi
  printf '%s' "$cwd"
}

function list_sessions {
  local json=${1:-0}

  # Pipe-delimited -o output (not --Format columns) so empty fields can't
  # shift the ones after them during parsing.
  local lines
  lines=$(squeue --me --states RUNNING --noheader -o '%i|%k|%N|%P|%M|%l' 2>/dev/null |
    awk -F'|' '$2 == "sinteractive" || index($2, "sinteractive:") == 1')

  if [[ -z "$lines" ]]; then
    if ((json)); then
      echo '[]'
    else
      echo "No running sinteractive sessions."
    fi
    exit 0
  fi

  # Query cwd for each session in parallel; results land in $tmpdir/<jobid>
  local tmpdir
  tmpdir=$(mktemp -d)
  trap 'rm -rf "$tmpdir"' EXIT
  local jobid comment node partition elapsed limit
  while IFS='|' read -r jobid comment node partition elapsed limit; do
    (get_session_cwd "$node" "$jobid" >"$tmpdir/$jobid") &
  done <<<"$lines"
  wait

  local name cwd
  if ((json)); then
    local out='[' first=1
    while IFS='|' read -r jobid comment node partition elapsed limit; do
      name=''
      if [[ "$comment" =~ ^sinteractive:(.+)$ ]]; then
        name="${BASH_REMATCH[1]}"
      fi
      cwd=$(<"$tmpdir/$jobid")
      ((first)) || out+=','
      first=0
      out+="{\"job_id\":${jobid},\"name\":$(json_string_or_null "$name")"
      out+=",\"node\":\"${node}\",\"partition\":\"${partition}\""
      out+=",\"elapsed\":\"${elapsed}\",\"time_limit\":\"${limit}\""
      out+=",\"cwd\":$(json_string_or_null "$cwd")}"
    done <<<"$lines"
    echo "${out}]"
    exit 0
  fi

  printf '%-10s  %-20s  %-14s  %-12s  %-10s  %-10s  %s\n' \
    'JOBID' 'NAME' 'NODE' 'PARTITION' 'ELAPSED' 'TIMELIMIT' 'CWD'
  while IFS='|' read -r jobid comment node partition elapsed limit; do
    name='-'
    if [[ "$comment" =~ ^sinteractive:(.+)$ ]]; then
      name="${BASH_REMATCH[1]}"
    fi
    cwd=$(<"$tmpdir/$jobid")
    [[ -z "$cwd" ]] && cwd='-'
    printf '%-10s  %-20s  %-14s  %-12s  %-10s  %-10s  %s\n' \
      "$jobid" "$name" "$node" "$partition" "$elapsed" "$limit" "$cwd"
  done <<<"$lines"

  echo ''
  echo 'To reattach:  sinteractive --attach JOBID  (or NAME if set)'
  exit 0
}

# Show status for one session (JOBID or NAME; defaults to the current session
# when run inside one). Human-readable by default; with json=1 emits a single
# JSON object for scripts and agents. Exits 0 if the job exists, 1 otherwise.
function show_status {
  local target=$1 json=$2

  if [[ -z "$target" ]]; then
    if [[ -n "${SINTERACTIVE_JOB_ID:-}" ]]; then
      target="${SINTERACTIVE_JOB_ID}"
    else
      echo 1>&2 "Error: --status requires a JOBID or NAME outside a session."
      echo 1>&2 "Run 'sinteractive --list' to see available sessions."
      exit 1
    fi
  fi

  local jobid
  jobid=$(resolve_session_jobid "$target") || exit 1

  local line
  line=$(squeue --jobs "$jobid" --noheader -o '%T|%e|%N|%P|%l|%M|%k' 2>/dev/null)
  if [[ -z "$line" ]]; then
    if ((json)); then
      printf '{"job_id":%s,"state":"NOT_FOUND"}\n' "$jobid"
    else
      echo 1>&2 "$0: job ${jobid} not found (finished or cancelled)"
    fi
    exit 1
  fi

  local state end_str node partition limit elapsed comment
  IFS='|' read -r state end_str node partition limit elapsed comment <<<"$line"

  local name=''
  if [[ "$comment" =~ ^sinteractive:(.+)$ ]]; then
    name="${BASH_REMATCH[1]}"
  fi

  local end_epoch='' remaining=''
  if [[ "$state" == 'RUNNING' ]]; then
    end_epoch=$(date -d "$end_str" +%s 2>/dev/null) || end_epoch=''
    if [[ -n "$end_epoch" ]]; then
      remaining=$((end_epoch - $(date +%s)))
      ((remaining < 0)) && remaining=0
    fi
  fi

  if ((json)); then
    printf '{"job_id":%s,"name":%s,"state":"%s","node":%s,"partition":"%s","time_limit":"%s","elapsed":"%s","end_epoch":%s,"remaining_seconds":%s}\n' \
      "$jobid" "$(json_string_or_null "$name")" "$state" \
      "$(json_string_or_null "$node")" "$partition" "$limit" "$elapsed" \
      "${end_epoch:-null}" "${remaining:-null}"
  else
    local title="Session ${jobid}"
    [[ -n "$name" ]] && title+=" (${name})"
    echo "${title}: ${state}${node:+ on ${node}}"
    printf '  %-11s %s\n' 'Partition:' "$partition"
    printf '  %-11s %s (limit %s)\n' 'Elapsed:' "$elapsed" "$limit"
    if [[ -n "$remaining" ]]; then
      printf '  %-11s %s\n' 'Remaining:' "$(format_short_duration "$remaining")"
    fi
  fi
  exit 0
}

# Extract the effective partition name from the processed argument list.
function get_partition_from_args {
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --partition=*)
      echo "${1#--partition=}"
      return
      ;;
    -p)
      echo "${2:-}"
      return
      ;;
    *)
      shift
      ;;
    esac
  done
  echo "interactive"
}

# Extract the effective --time / -t value from the processed argument list.
# Echoes the value (e.g. "24:00:00", "1-12:00:00", "120") and returns 0; if
# no time is set, returns 1.
function extract_time_from_args {
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --time=*)
      echo "${1#--time=}"
      return 0
      ;;
    --time)
      echo "${2:-}"
      return 0
      ;;
    -t)
      echo "${2:-}"
      return 0
      ;;
    -t=*)
      echo "${1#-t=}"
      return 0
      ;;
    *)
      shift
      ;;
    esac
  done
  return 1
}

# Convert a SLURM time string to whole seconds. Echoes the integer and returns
# 0 on success; returns 1 if the format isn't recognized (caller should fail
# open).
function slurm_time_to_seconds {
  local t=$1
  local d=0 h=0 m=0 s=0
  if [[ "$t" =~ ^([0-9]+)-([0-9]+):([0-9]+):([0-9]+)$ ]]; then
    d=${BASH_REMATCH[1]}
    h=${BASH_REMATCH[2]}
    m=${BASH_REMATCH[3]}
    s=${BASH_REMATCH[4]}
  elif [[ "$t" =~ ^([0-9]+)-([0-9]+):([0-9]+)$ ]]; then
    d=${BASH_REMATCH[1]}
    h=${BASH_REMATCH[2]}
    m=${BASH_REMATCH[3]}
  elif [[ "$t" =~ ^([0-9]+)-([0-9]+)$ ]]; then
    d=${BASH_REMATCH[1]}
    h=${BASH_REMATCH[2]}
  elif [[ "$t" =~ ^([0-9]+):([0-9]+):([0-9]+)$ ]]; then
    h=${BASH_REMATCH[1]}
    m=${BASH_REMATCH[2]}
    s=${BASH_REMATCH[3]}
  elif [[ "$t" =~ ^([0-9]+):([0-9]+)$ ]]; then
    m=${BASH_REMATCH[1]}
    s=${BASH_REMATCH[2]}
  elif [[ "$t" =~ ^([0-9]+)$ ]]; then
    m=${BASH_REMATCH[1]}
  else
    return 1
  fi
  echo $((d * 86400 + 10#$h * 3600 + 10#$m * 60 + 10#$s))
}

# Format seconds as a short human duration like "1d 2h 5m" or "45m".
function format_short_duration {
  local secs=$1
  local d=$((secs / 86400))
  local h=$(((secs % 86400) / 3600))
  local m=$(((secs % 3600) / 60))
  local out=""
  ((d > 0)) && out+="${d}d "
  ((h > 0)) && out+="${h}h "
  ((m > 0)) && out+="${m}m"
  # Below one minute, minute granularity reads as a confusing "0m".
  ((d == 0 && h == 0 && m == 0)) && out="${secs}s"
  echo "${out% }"
}

# Refuse to submit if the requested --time would overlap an upcoming MAINT
# reservation. Returns 0 to proceed, 1 to abort. Fails open silently when
# scontrol is unavailable, no MAINT reservation is queued, or the time string
# can't be parsed (the scheduler will still apply its own constraints).
function check_maintenance_window {
  # User explicitly opted into a reservation — trust them
  local arg
  for arg in "$@"; do
    case "$arg" in
    --reservation=* | --reservation) return 0 ;;
    esac
  done

  local resv_out
  resv_out=$(scontrol show reservation -o 2>/dev/null) || return 0
  [[ -z "$resv_out" ]] && return 0
  [[ "$resv_out" == "No reservations"* ]] && return 0

  local now_epoch best_epoch=0 best_name=""
  now_epoch=$(date +%s)

  local line start_str start_epoch
  while IFS= read -r line; do
    [[ "$line" =~ Flags=[^[:space:]]*MAINT ]] || continue
    [[ "$line" =~ StartTime=([^[:space:]]+) ]] || continue
    start_str=${BASH_REMATCH[1]}
    start_epoch=$(date -d "$start_str" +%s 2>/dev/null) || continue
    ((start_epoch > now_epoch)) || continue
    if ((best_epoch == 0 || start_epoch < best_epoch)); then
      best_epoch=$start_epoch
      if [[ "$line" =~ ReservationName=([^[:space:]]+) ]]; then
        best_name=${BASH_REMATCH[1]}
      fi
    fi
  done <<<"$resv_out"

  ((best_epoch == 0)) && return 0

  local time_str time_secs
  time_str=$(extract_time_from_args "$@") || return 0
  time_secs=$(slurm_time_to_seconds "$time_str") || return 0

  local job_end=$((now_epoch + time_secs))
  ((job_end <= best_epoch)) && return 0

  local gap_secs=$((best_epoch - now_epoch))
  local overlap_secs=$((job_end - best_epoch))
  local fit_secs=$((gap_secs - 300))

  local maint_when end_when
  maint_when=$(date -d "@$best_epoch" "+%a %b %-d %H:%M")
  end_when=$(date -d "@$job_end" "+%a %b %-d %H:%M")

  local suggestion=""
  if ((fit_secs >= 3600)); then
    suggestion="sinteractive --time=$((fit_secs / 3600))h"
  elif ((fit_secs >= 60)); then
    suggestion="sinteractive --time=$((fit_secs / 60))m"
  fi

  echo 1>&2 ""
  echo 1>&2 "Error: --time=${time_str} conflicts with scheduled maintenance."
  echo 1>&2 ""
  echo 1>&2 "  Reservation: ${best_name:-<unnamed>}"
  echo 1>&2 "  Starts:      ${maint_when} (in $(format_short_duration $gap_secs))"
  echo 1>&2 "  Job would end: ${end_when} ($(format_short_duration $overlap_secs) past start)"
  echo 1>&2 ""
  if [[ -n "$suggestion" ]]; then
    echo 1>&2 "Slurm won't schedule this job until after the reservation ends. To start"
    echo 1>&2 "a session now, shorten --time to fit before maintenance:"
    echo 1>&2 ""
    echo 1>&2 "  ${suggestion}"
  else
    echo 1>&2 "The window before maintenance is too short for a useful session."
    echo 1>&2 "Wait until after the reservation ends."
  fi
  echo 1>&2 ""
  echo 1>&2 "See 'scontrol show reservation' for full details."
  echo 1>&2 ""
  return 1
}

# Check if submitting another job would exceed the QOS MaxJobsPerUser limit.
# Only checks when targeting the interactive partition.
# Falls through silently if sacctmgr or squeue are unavailable.
function check_job_limit {
  local partition="$1"

  # Only enforce for the interactive partition
  if [[ "$partition" != "interactive" ]]; then
    return 0
  fi

  # Query QOS limit dynamically; fail open if sacctmgr unavailable
  local max_jobs
  max_jobs=$(sacctmgr show qos interactive format=MaxJobsPerUser --noheader --parsable2 2>/dev/null)
  if [[ $? -ne 0 ]] || [[ -z "$max_jobs" ]]; then
    return 0
  fi

  max_jobs=$(echo "$max_jobs" | xargs)

  if ! [[ "$max_jobs" =~ ^[0-9]+$ ]]; then
    return 0
  fi

  # Count current running + pending jobs on the interactive partition
  local current_jobs
  current_jobs=$(squeue --me --partition=interactive --states=RUNNING,PENDING --noheader 2>/dev/null | wc -l)
  if [[ $? -ne 0 ]]; then
    return 0
  fi

  current_jobs=$(echo "$current_jobs" | xargs)

  if ((current_jobs >= max_jobs)); then
    echo 1>&2 ""
    echo 1>&2 "Error: You already have ${current_jobs}/${max_jobs} interactive jobs (the maximum allowed)."
    echo 1>&2 ""

    local lines
    lines=$(squeue --me --partition=interactive --states=RUNNING,PENDING --noheader \
      --Format=JobID:12,Name:20,NodeList:16,State:10,TimeUsed:12,TimeLimit:12 2>/dev/null)

    if [[ -n "$lines" ]]; then
      echo 1>&2 "Your current interactive jobs:"
      echo 1>&2 ""
      printf 1>&2 '  %-10s  %-18s  %-14s  %-9s  %-10s  %-10s\n' \
        'JOBID' 'NAME' 'NODE' 'STATE' 'ELAPSED' 'TIMELIMIT'
      while IFS= read -r line; do
        read -r jobid name node state elapsed limit <<<"$line"
        printf 1>&2 '  %-10s  %-18s  %-14s  %-9s  %-10s  %-10s\n' \
          "$jobid" "$name" "$node" "$state" "$elapsed" "$limit"
      done <<<"$lines"
      echo 1>&2 ""
    fi

    echo 1>&2 "To reattach to an existing session:"
    local jobids
    jobids=$(squeue --me --partition=interactive --states=RUNNING --noheader --Format=JobID 2>/dev/null | xargs)
    for jid in $jobids; do
      echo 1>&2 "  sinteractive --attach $jid"
    done
    echo 1>&2 ""
    echo 1>&2 "To free a slot, cancel a session:"
    jobids=$(squeue --me --partition=interactive --states=RUNNING,PENDING --noheader --Format=JobID 2>/dev/null | xargs)
    for jid in $jobids; do
      echo 1>&2 "  scancel $jid"
    done
    echo 1>&2 ""
    return 1
  fi

  return 0
}

# Resolve a JOBID-or-NAME target to a job id. Numeric targets pass through;
# names are matched against the Comment marker set at submit time. Prints the
# job id on stdout; errors (to stderr) and returns nonzero on no match or
# ambiguity, so call as: jobid=$(resolve_session_jobid "$target") || exit 1
function resolve_session_jobid {
  local target=$1

  if [[ "${target}" =~ ^[0-9]+$ ]]; then
    echo "${target}"
    return 0
  fi

  local matches
  matches=$(squeue --me --states RUNNING,PENDING --noheader \
    --Format=JobID:12,Comment:80 2>/dev/null |
    awk -v n="sinteractive:${target}" '$2 == n {print $1}')
  local count
  count=$(printf '%s\n' "${matches}" | grep -c .)
  if [[ "${count}" -eq 0 ]]; then
    echo 1>&2 "$0: no sinteractive session named '${target}'"
    echo 1>&2 "Run 'sinteractive --list' to see available sessions."
    return 1
  elif [[ "${count}" -gt 1 ]]; then
    echo 1>&2 "$0: multiple sinteractive sessions named '${target}':"
    echo 1>&2 "  $(echo ${matches} | xargs)"
    echo 1>&2 "Specify a JOBID instead."
    return 1
  fi
  echo "${matches}"
}

function reattach {
  local target=$1
  local jobid

  jobid=$(resolve_session_jobid "${target}") || exit 1

  local sock="sinteractive-${jobid}"

  # Verify the job is still running
  local state
  state=$(squeue --jobs "${jobid}" --states RUNNING --noheader --Format state 2>/dev/null | xargs)
  if [[ "${state}" != 'RUNNING' ]]; then
    echo 1>&2 "$0: job ${jobid} is not running (state: ${state:-unknown})"
    exit 1
  fi

  echo 1>&2 "Reattaching to sinteractive session ${jobid}..."
  exec srun --overlap --jobid="${jobid}" --pty \
    $TMUX_BIN -L "$sock" -u attach-session -t "sinteractive-${jobid}"
}

# Render the in-session help modal. Runs inside a tmux display-popup on the
# compute node (invoked as "help-popup JOBID" via the spooled batch script).
# Job info is queried live so time remaining is current each time the popup
# opens; any keypress closes it. Degrades to '-' if squeue is unavailable.
function show_help_popup {
  local jobid="${1:-}"

  local node='-' limit='-' remaining='-'
  local info
  info=$(squeue --jobs "$jobid" --noheader \
    --Format=EndTime:24,NodeList:20,TimeLimit:12 2>/dev/null | xargs)
  if [[ -n "$info" ]]; then
    local end_str
    read -r end_str node limit <<<"$info"
    local end_epoch
    end_epoch=$(date -d "$end_str" +%s 2>/dev/null)
    if [[ -n "$end_epoch" ]]; then
      local secs=$((end_epoch - $(date +%s)))
      ((secs < 0)) && secs=0
      remaining=$(format_short_duration "$secs")
    fi
  fi

  # ANSI styles; the popup always renders on a terminal. Yellow keys echo the
  # status-bar highlight (colour229).
  local rst=$'\e[0m' bold=$'\e[1m' dim=$'\e[2m' url=$'\e[4;36m'
  local hdr=$'\e[1;36m' key=$'\e[1;33m'
  # OSC 8 hyperlink so the docs URL is clickable in terminals that support it
  # (needs the hyperlinks terminal-feature set in start_tmux to pass through).
  local docs='https://tinyurl.com/2s45khbx'
  local lnk=$'\e]8;;'"$docs"$'\e\\' lnk_end=$'\e]8;;\e\\'

  cat <<EOF

  ${bold}Job ${jobid:-?} on ${node}${rst} | ${key}${remaining}${rst} remaining ${dim}(limit ${limit})${rst}

  ${hdr}Session${rst}
    Detach (keeps job running)   ${key}Ctrl+b d${rst}
    Name/rename session          ${key}Ctrl+b \$${rst}
    Reattach from login node     ${key}sinteractive --attach ${jobid:-JOBID}${rst}
    List your sessions           ${key}sinteractive --list${rst}
    End session and job          ${key}exit${rst} ${dim}(in all panes)${rst}

  ${hdr}tmux basics${rst}
    Split pane (top/bottom)      ${key}Ctrl+b "${rst}
    Split pane (side/side)       ${key}Ctrl+b %${rst}
    Switch panes                 ${key}Ctrl+b arrow-key${rst}
    Scrollback                   ${key}Ctrl+b [${rst}  ${dim}(q to exit)${rst}

  Docs: ${url}${lnk}${docs}${lnk_end}${rst}

  ${dim}Press any key to close.${rst}
EOF
  read -rsn1
}

# Flash a message in the status line of every attached client. Handlers run
# via run-shell with no client context, so target clients explicitly; with no
# clients attached (detached session) this is a silent no-op.
function display_to_clients {
  local jobid="$1" delay="$2" msg="$3"
  local sock="sinteractive-${jobid}"
  local client
  while IFS= read -r client; do
    $TMUX_BIN -L "$sock" display-message -d "$delay" -c "$client" "$msg"
  done < <($TMUX_BIN -L "$sock" list-clients -F '#{client_name}' 2>/dev/null)
}

# Name or rename a running session in place (bound to prefix + $ in
# start_tmux). Runs on the compute node via run-shell. Updates, in order:
# the Slurm Comment marker (what --attach/--list/--status resolve against),
# the Slurm job name (cosmetic, shows in squeue), and the tmux session
# environment SINTERACTIVE_NAME (drives the status bar, terminal title, and
# state file; new panes inherit it). Shells already running keep their old
# SINTERACTIVE_NAME — deliberately no send-keys, which could type into a
# foreground program.
function rename_session {
  local jobid="$1"
  local new_name="${2:-}"
  local sock="sinteractive-${jobid}"
  local session="sinteractive-${jobid}"

  # Bare Enter at the prompt = cancel.
  [[ -z "$new_name" ]] && return 0

  if ! [[ "$new_name" =~ ^[A-Za-z0-9._-]+$ ]]; then
    display_to_clients "$jobid" 5000 \
      "rename failed: name must contain only letters, digits, '.', '_', '-'"
    return 1
  fi

  # Duplicate-name guard, excluding this job so renaming to the current name
  # is a clean no-op. squeue failure fails open, matching the submit side.
  local existing
  existing=$(squeue --me --states RUNNING,PENDING --noheader \
    --Format=JobID:12,Comment:80 2>/dev/null |
    awk -v n="sinteractive:${new_name}" -v me="$jobid" '$2 == n && $1 != me {print $1}')
  if [[ -n "$existing" ]]; then
    display_to_clients "$jobid" 5000 \
      "rename failed: '${new_name}' is already used by job $(echo ${existing} | xargs)"
    return 1
  fi

  # Comment first: it is what name-based lookups match on. If it fails
  # (e.g. slurmctld unreachable), stop before touching the tmux env so
  # Slurm and tmux stay consistent on the old name.
  local err
  if ! err=$(scontrol update JobId="$jobid" Comment="sinteractive:${new_name}" 2>&1); then
    display_to_clients "$jobid" 5000 "rename failed: ${err}"
    return 1
  fi
  # Job name is cosmetic (squeue display); best-effort.
  scontrol update JobId="$jobid" Name="sint-${new_name}" 2>/dev/null || true

  $TMUX_BIN -L "$sock" set-environment -t "$session" SINTERACTIVE_NAME "$new_name"

  # Poke status_dot_loop so the state-file name refreshes next tick instead
  # of waiting out its 30s write cache.
  touch "${HOME}/.cache/sinteractive/${jobid}.poke" 2>/dev/null || true

  display_to_clients "$jobid" 2000 "session renamed to '${new_name}'"
}

# Background updater for the status-bar glyph: a dot in the terminal's
# default foreground color (adapts to light/dark themes) while plenty of
# walltime remains, a pulsing yellow dot plus countdown once less than
# SINTERACTIVE_WARN_YELLOW seconds are left (default 1 hour), and a braille
# spinner blinking yellow/red with an M:SS countdown for the final
# SINTERACTIVE_WARN_RED seconds (default 10 minutes). (Braille cells are
# single-width everywhere; the quadrant clocks ◴◵◶◷ used previously are
# East Asian Ambiguous width and jitter in some fonts.) A few seconds
# before the limit it prints a notice in every pane and kills the session
# itself, so teardown runs the normal exit path (clean client detach, job
# COMPLETED) instead of Slurm's SIGTERM/SIGKILL tearing tmux down
# mid-frame. Replaces the old USR1-driven warning banner at the top of the
# pane. Runs until the tmux session ends; killed with the job's cgroup at
# teardown.
function status_dot_loop {
  local session_name="$1"
  local disp_name="${2:-}"
  local sock="sinteractive-${SLURM_JOB_ID}"

  local warn_yellow="${SINTERACTIVE_WARN_YELLOW:-3600}"
  local warn_red="${SINTERACTIVE_WARN_RED:-600}"
  # Seconds before the limit at which the session is shut down cleanly.
  # Env-tunable mainly for testing (e.g. SINTERACTIVE_GRACE=55 --time=1
  # fires the shutdown a few seconds after launch).
  local grace="${SINTERACTIVE_GRACE:-10}"

  # State file mirroring the countdown, so scripts and agents can poll the
  # time budget without hitting the scheduler. $HOME is shared, so it is
  # readable from the login node too. Removed at session teardown.
  local state_dir="${HOME}/.cache/sinteractive"
  local state_file="${state_dir}/${SLURM_JOB_ID}.json"
  mkdir -p "$state_dir"
  local host
  host=$(hostname -s)
  local state_written=0

  # Everything after the glyph is fixed; the loop only swaps the glyph and
  # appends a countdown. Must mirror the initial status-left in start_tmux.
  # The trailing conditional shows the session name when one is set; tmux
  # format lookup falls back to the session environment, so a prefix+$
  # rename (set-environment SINTERACTIVE_NAME) appears on the next redraw
  # without this loop rebuilding anything.
  # (The #, inside the conditional escapes the style comma, which would
  # otherwise terminate the branch.)
  local base=" #[dim]session#[default] #[fg=#2DBFB8,bold]${SLURM_JOB_ID}#[default] #[dim]|#[default] #[fg=#2DBFB8,bold]#{host_short}#[default]#{?SINTERACTIVE_NAME, #[dim]|#[default] #[fg=#2DBFB8#,bold]#{SINTERACTIVE_NAME}#[default],}"

  local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local end_epoch='' end_query=0 spin=0 belled=0 last=''
  while $TMUX_BIN -L "$sock" has-session -t "$session_name" 2>/dev/null; do
    local now remaining
    # printf's builtin strftime — no date fork, which matters at the
    # 10 ticks/second cadence of the final countdown.
    printf -v now '%(%s)T' -1

    # A poke file (touched by rename_session) forces an immediate state-file
    # write instead of waiting out the 30-second cache below.
    if [[ -e "${state_file%.json}.poke" ]]; then
      rm -f "${state_file%.json}.poke"
      state_written=0
    fi

    # (Re-)query the scheduler for the job end time every 5 minutes so a
    # scontrol timelimit update moves the clock; keep the previous value on
    # transient squeue failures.
    if ((now - end_query >= 300)); then
      end_query=$now
      local end_str new_epoch
      end_str=$(squeue --jobs "${SLURM_JOB_ID}" --noheader --Format EndTime 2>/dev/null | xargs)
      if [[ -n "$end_str" ]]; then
        new_epoch=$(date -d "$end_str" +%s 2>/dev/null) && end_epoch=$new_epoch
      fi
    fi
    # No parseable end time yet (UNLIMITED, squeue hiccup): leave the white
    # dot alone and try again later.
    if [[ -z "$end_epoch" ]]; then
      sleep 60
      continue
    fi

    remaining=$((end_epoch - now))
    ((remaining < 0)) && remaining=0

    # Refresh the state file at most every 30s (the loop ticks up to ten
    # times a second during the final countdown); write-then-rename keeps
    # reads atomic.
    if ((now - state_written >= 30)); then
      state_written=$now
      # Re-read the name each write so a prefix+$ rename lands in the state
      # file; the tmux session environment is the source of truth. Keep the
      # captured value as fallback when the var was never set.
      local env_name
      if env_name=$($TMUX_BIN -L "$sock" show-environment -t "$session_name" SINTERACTIVE_NAME 2>/dev/null); then
        disp_name="${env_name#*=}"
      fi
      printf '{"job_id":%s,"name":%s,"node":"%s","end_epoch":%s,"remaining_seconds":%s,"updated_epoch":%s}\n' \
        "${SLURM_JOB_ID}" "$(json_string_or_null "$disp_name")" "$host" \
        "$end_epoch" "$remaining" "$now" >"${state_file}.tmp" &&
        mv -f "${state_file}.tmp" "$state_file"
    fi

    local glyph text sleep_for
    if ((remaining > warn_yellow)); then
      glyph='#[bold]●#[default]'
      text=''
      # Wake at the yellow boundary when it lands inside the normal cadence,
      # so the yellow phase starts on time (not up to 59s late — which in
      # short sessions skipped it entirely).
      sleep_for=$((remaining - warn_yellow < 60 ? remaining - warn_yellow : 60))
      ((sleep_for < 1)) && sleep_for=1
      belled=0
    elif ((remaining > warn_red)); then
      # Pulse the dot bold/dim once a second — catches the eye without the
      # urgency of the red phase's spinner.
      if ((spin % 2)); then
        glyph='#[fg=yellow,dim]●#[default]'
      else
        glyph='#[fg=yellow,bold]●#[default]'
      fi
      spin=$((spin + 1))
      text=" #[dim]| $(format_short_duration "$remaining") left#[default]"
      sleep_for=1
      belled=0
    else
      # Ring the terminal bell once as the final countdown starts: writing
      # BEL to a pane's tty registers as a pane bell, which tmux forwards to
      # attached clients (default bell-action any), so the terminal tab gets
      # an attention badge even when the user is looking at another window.
      if ((!belled)); then
        belled=1
        local pane_tty
        while read -r pane_tty; do
          printf '\a' >"$pane_tty" 2>/dev/null || true
        done < <($TMUX_BIN -L "$sock" list-panes -s -t "$session_name" -F '#{pane_tty}')
      fi
      # Almost out of time: end the session ourselves so teardown runs the
      # normal exit path (farewell in every pane, clean client detach, job
      # COMPLETED via the session-closed hook) instead of Slurm's
      # SIGTERM/SIGKILL tearing tmux down mid-frame.
      if ((remaining <= grace)); then
        # end_epoch can be up to 5 minutes stale; re-check so a timelimit
        # extension inside that window is honored rather than cut short.
        local end_str new_epoch
        end_str=$(squeue --jobs "${SLURM_JOB_ID}" --noheader --Format EndTime 2>/dev/null | xargs)
        if [[ -n "$end_str" ]] && new_epoch=$(date -d "$end_str" +%s 2>/dev/null); then
          end_epoch=$new_epoch
          end_query=$now
          if ((end_epoch - now > grace)); then
            continue
          fi
        fi
        $TMUX_BIN -L "$sock" set-option -t "$session_name" status-left \
          " #[fg=red,bold]●#[default]${base} #[fg=red,bold]| time's up — ending session#[default] "
        local pane_tty
        while read -r pane_tty; do
          printf '\r\n\033[1;31m[sinteractive] walltime reached — ending session\033[0m\r\n' \
            >"$pane_tty" 2>/dev/null || true
        done < <($TMUX_BIN -L "$sock" list-panes -s -t "$session_name" -F '#{pane_tty}')
        sleep 2
        $TMUX_BIN -L "$sock" kill-session -t "$session_name" 2>/dev/null
        break
      fi
      # Spin at 10 frames/second so the motion is fluid; blink yellow/red
      # keyed to the countdown's seconds parity so the color change stays a
      # calm once-a-second beat rather than a 10 Hz strobe.
      local color=yellow
      ((remaining % 2)) && color=red
      glyph="#[fg=${color},bold]${frames[spin % 10]}#[default]"
      printf -v text ' #[fg=%s,bold]| %d:%02d left#[default]' \
        "$color" $((remaining / 60)) $((remaining % 60))
      spin=$((spin + 1))
      sleep_for=0.1
    fi

    local left=" ${glyph}${base}${text} "
    if [[ "$left" != "$last" ]]; then
      $TMUX_BIN -L "$sock" set-option -t "$session_name" status-left "$left"
      last="$left"
    fi
    sleep "$sleep_for"
  done

  rm -f "$state_file" "${state_file}.tmp" "${state_file%.json}.poke"
}

function start_tmux {
  export TERM=xterm-256color

  # Optional feature flags passed after "tmux" on the sbatch command line.
  local enable_mouse=0
  local disp_name=''
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --mouse)
      enable_mouse=1
      shift
      ;;
    --session-name=*)
      disp_name="${1#--session-name=}"
      shift
      ;;
    *) shift ;;
    esac
  done

  local session_name="sinteractive-${SLURM_JOB_ID}"
  local wait_channel="sinteractive-done-${SLURM_JOB_ID}"
  local sock="sinteractive-${SLURM_JOB_ID}"

  # Each job gets its own tmux server socket (-L) so that SLURM cgroup
  # cleanup for one job does not kill the tmux server shared by others.
  $TMUX_BIN -L "$sock" -u new-session -d -s "$session_name"

  # tmux >= 3.7 resizes existing panes when history-limit changes, so setting
  # it globally after new-session applies to the initial pane too; every split
  # inherits the global value.
  $TMUX_BIN -L "$sock" set-option -g history-limit 50000

  # OSC 52 clipboard integration (copy works over SSH)
  $TMUX_BIN -L "$sock" set-option -t "$session_name" set-clipboard on
  # OSC 8 hyperlinks (docs link in the help popup): tmux only re-emits them to
  # clients whose terminal declares the feature, and it can't detect support
  # from TERM alone, so assert it for all clients. Terminals without OSC 8
  # ignore the sequence; the link text still renders.
  $TMUX_BIN -L "$sock" set-option -sa terminal-features ',*:hyperlinks'
  # Let applications see terminal focus changes (autoread, cursor-shape, etc.).
  # escape-time is left at the tmux >= 3.5 default of 10ms (snappy ESC in vim).
  $TMUX_BIN -L "$sock" set-option -t "$session_name" focus-events on
  # Keep dead panes visible on non-zero exit for debugging (tmux >= 3.4).
  $TMUX_BIN -L "$sock" set-option -t "$session_name" remain-on-exit failed
  # pane-died: on Ctrl-C/SIGINT (exit 130) respawn the pane instead of leaving
  # "Pane is dead"; otherwise, if the dead pane was the last LIVE pane in the
  # session, end the session so the job exits. Without this, a login shell
  # exiting non-zero (e.g. a failed last command then Ctrl-D) would linger as a
  # dead pane, keeping session-closed from firing and stranding the allocation.
  # Dead panes in a multi-pane layout are still kept for inspection.
  $TMUX_BIN -L "$sock" set-hook -t "$session_name" pane-died \
    "run-shell \"if [ '#{pane_dead_status}' = 130 ]; then $TMUX_BIN -L $sock respawn-pane -k -t '#{pane_id}'; elif [ \\\$($TMUX_BIN -L $sock list-panes -s -t $session_name -F '##{pane_dead}' | grep -cx 0) -eq 0 ]; then $TMUX_BIN -L $sock kill-session -t $session_name; fi\""
  # Highlight windows with new activity
  $TMUX_BIN -L "$sock" set-option -t "$session_name" monitor-activity on
  # Auto-rename windows to current command
  $TMUX_BIN -L "$sock" set-option -t "$session_name" automatic-rename on
  # Opt-in mouse support (--mouse): wheel scrollback, click to select panes,
  # drag borders to resize. Off by default because it intercepts terminal
  # selection (hold Shift to select for an OS-level copy); with set-clipboard
  # on, tmux's own mouse selection copies out over SSH via OSC 52.
  if ((enable_mouse)); then
    $TMUX_BIN -L "$sock" set-option -t "$session_name" mouse on
    # tmux >= 3.6: show a per-pane scrollbar so wheel scrollback has a visible
    # position indicator. tmux >= 3.7: focus the pane under the cursor.
    $TMUX_BIN -L "$sock" set-option -t "$session_name" pane-scrollbars on
    $TMUX_BIN -L "$sock" set-option -t "$session_name" focus-follows-mouse on
  fi

  # Strip SLURM vars from tmux session so child processes (e.g. snakemake)
  # don't think they're running as a SLURM job step.
  # set-environment -u prevents future panes from inheriting the vars;
  # send-keys unsets them in the already-running initial shell.
  for var in $(env | grep ^SLURM_ | cut -d= -f1); do
    $TMUX_BIN -L "$sock" set-environment -t "$session_name" -u "$var"
  done

  # Expose the job identity to shells inside the session, so tools and agents
  # can introspect ("sinteractive --status" with no target reports on the
  # current session). set-environment covers panes created later; the
  # send-keys below covers the already-running initial shell.
  $TMUX_BIN -L "$sock" set-environment -t "$session_name" SINTERACTIVE_JOB_ID "${SLURM_JOB_ID}"
  local init_env="export SINTERACTIVE_JOB_ID=${SLURM_JOB_ID}"
  if [[ -n "$disp_name" ]]; then
    $TMUX_BIN -L "$sock" set-environment -t "$session_name" SINTERACTIVE_NAME "$disp_name"
    init_env+=" SINTERACTIVE_NAME=${disp_name}"
  fi
  $TMUX_BIN -L "$sock" send-keys -t "$session_name" \
    " unset \${!SLURM_@}; ${init_env}; clear" Enter

  # Status bar: no background color (terminal default), separated from the
  # pane by a thin border line. Left = a status glyph (a dot in the default
  # foreground color, so it adapts to light and dark themes; becomes a
  # time-remaining clock near the limit — see status_dot_loop, which keeps
  # this string updated) and the job ID + host in bold cyan (#2DBFB8, the
  # teal-cyan rustc/cargo use for ANSI cyan), with the label and separator
  # dimmed. Right = hint for the help popup; the full help (reattach command,
  # docs link, tmux keys) lives in the Ctrl+b h modal.
  # The trailing conditional appends "| <name>" when the session has a name.
  # tmux format lookup falls back to the session environment, so the segment
  # tracks SINTERACTIVE_NAME live (set at launch with --name, or later via
  # prefix+$). Must mirror the base string in status_dot_loop. The #, inside
  # the conditional escapes the style comma, which would otherwise terminate
  # the branch.
  local name_fmt='#{?SINTERACTIVE_NAME, #[dim]|#[default] #[fg=#2DBFB8#,bold]#{SINTERACTIVE_NAME}#[default],}'
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-style 'fg=default,bg=default'
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-left \
    " #[bold]●#[default] #[dim]session#[default] #[fg=#2DBFB8,bold]${SLURM_JOB_ID}#[default] #[dim]|#[default] #[fg=#2DBFB8,bold]#{host_short}#[default]${name_fmt} "
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-left-length 80
  # Hide the window list (0:bash*) from the center of the status bar
  $TMUX_BIN -L "$sock" set-option -t "$session_name" window-status-format ''
  $TMUX_BIN -L "$sock" set-option -t "$session_name" window-status-current-format ''
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-right \
    " Help: #[fg=yellow,bold]Ctrl+b h#[default] | Detach: #[fg=yellow,bold]Ctrl+b d#[default] "
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-right-length 40
  # Terminal window/tab title (OSC 2): mirror the status-left text so users
  # with several sessions can tell tabs apart at a glance.
  $TMUX_BIN -L "$sock" set-option -t "$session_name" set-titles on
  $TMUX_BIN -L "$sock" set-option -t "$session_name" set-titles-string \
    "session ${SLURM_JOB_ID} | #{host_short}#{?SINTERACTIVE_NAME, | #{SINTERACTIVE_NAME},}"
  # Separator line between the terminal and the status bar: show the pane's
  # bottom border as a heavy rule in palette yellow (empty format = no title
  # text). Palette yellow, not a hex value, so light themes that remap
  # yellow to a darker amber keep the rule visible on white backgrounds
  # (hardcoded #F0E442 was ~1.3:1 contrast on white — invisible). Global so
  # windows created later get it too.
  $TMUX_BIN -L "$sock" set-option -g pane-border-status bottom
  $TMUX_BIN -L "$sock" set-option -g pane-border-format ''
  $TMUX_BIN -L "$sock" set-option -g pane-border-lines heavy
  $TMUX_BIN -L "$sock" set-option -g pane-border-style 'fg=yellow'
  $TMUX_BIN -L "$sock" set-option -g pane-active-border-style 'fg=yellow'

  # Help popup: prefix + h opens a modal with job info and key help, closed by
  # any key. Bindings are per-server, and each job has its own socket, so this
  # can't leak into other tmux servers. BASH_SOURCE here is Slurm's spooled
  # copy of this script, which stays executable on this node for the job's
  # lifetime, so the popup can re-invoke it as "help-popup JOBID".
  $TMUX_BIN -L "$sock" bind-key h display-popup -E -w 76 -h 22 \
    -T ' sinteractive help ' \
    "'${BASH_SOURCE[0]}' help-popup ${SLURM_JOB_ID}"

  # Name/rename the session in place: prefix + $ prompts for a name and
  # hands it to the rename-session handler (scontrol Comment/Name update,
  # SINTERACTIVE_NAME env). This deliberately overrides tmux's stock $
  # (rename-session): renaming the tmux session itself would desync
  # status_dot_loop's has-session/set-option targets and the literal session
  # name baked into the pane-died hook above. The prompt is prefilled with
  # the current name (format lookup falls back to the session environment).
  # Quoting: tmux substitutes %%% for the reply, backslash-escaping
  # double-quote/backslash/dollar/semicolon/tilde; the single-quoted tmux
  # template passes those through to run-shell's /bin/sh -c, where the inner
  # double quotes are exactly right. A literal single quote in the reply
  # breaks tmux parsing with a status-line error before the handler runs —
  # cosmetic only, on the user's own per-job server, and no such input would
  # pass the handler's name validation anyway.
  $TMUX_BIN -L "$sock" bind-key '$' command-prompt -p ' session name:' \
    -I '#{SINTERACTIVE_NAME}' \
    "run-shell '\"${BASH_SOURCE[0]}\" rename-session ${SLURM_JOB_ID} \"%%%\"'"

  $TMUX_BIN -L "$sock" set-hook -t "$session_name" session-closed \
    "run-shell '$TMUX_BIN -L $sock wait-for -S $wait_channel'"

  # Keep the status-bar glyph in sync with the job's time remaining.
  status_dot_loop "$session_name" "$disp_name" &

  # Ignore USR1: nothing traps it anymore (the old warning banner did), and
  # the default disposition would kill this batch shell if the user submits
  # with their own --signal=B:USR1.
  trap ':' USR1

  # Slurm delivers SIGTERM on scancel and at timeout (SIGKILL follows after
  # KillWait); remove the state file on the way out so it can't go stale.
  trap 'rm -f "${HOME}/.cache/sinteractive/${SLURM_JOB_ID}.json" \
    "${HOME}/.cache/sinteractive/${SLURM_JOB_ID}.json.tmp" \
    "${HOME}/.cache/sinteractive/${SLURM_JOB_ID}.poke"; exit 0' TERM

  # Run wait-for in background; `wait` builtin (foreground) is interruptible
  # by signals, unlike external commands which block trap delivery in bash.
  $TMUX_BIN -L "$sock" wait-for "$wait_channel" &
  local wait_pid=$!
  while true; do
    wait $wait_pid
    # 0 or 1-128 = process exited; >128 = signal interrupted wait
    if (($? <= 128)); then
      break
    fi
  done

  # Belt-and-braces: status_dot_loop removes its state file when it sees the
  # session die, but Slurm's cgroup cleanup can kill it mid-sleep first.
  rm -f "${HOME}/.cache/sinteractive/${SLURM_JOB_ID}.json" \
    "${HOME}/.cache/sinteractive/${SLURM_JOB_ID}.json.tmp" \
    "${HOME}/.cache/sinteractive/${SLURM_JOB_ID}.poke"

  trap - USR1
}

function attach_tmux {
  local SESSION=$1
  local sock="$SESSION"

  if [[ "${DISPLAY:-}" != '' ]]; then
    $TMUX_BIN -L "$sock" setenv -t "$SESSION" DISPLAY "$DISPLAY"
  fi

  exec $TMUX_BIN -L "$sock" -u attach-session -t "$SESSION"
}

function cleanup {
  if [[ -n "${JOB_ID}" ]]; then
    scancel --quiet "${JOB_ID}"
  fi

  exit
}

trap cleanup SIGINT SIGTERM EXIT

main "$@"
