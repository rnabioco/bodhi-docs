#!/bin/bash
# -*- coding: utf-8 -*-
#
# sinteractive — start an interactive shell on a Slurm compute node.
#
# Submits a batch job that launches a detached tmux session on the
# allocated node, then SSHes in and attaches to it. Because the shell
# lives in tmux, the session survives SSH drops and can be reattached
# later (see --attach / --list).
#
# Clean-room reimplementation, inspired by the original sinteractive by
# Pär Andersson (NSC, Sweden) and the later CU Boulder adaptation by
# Jonathon Anderson. Maintained by Jay Hesselberth.

# Treat unset variables as errors; the argument handling below guards every
# optional value explicitly, so this only fires on genuine bugs.
set -u

TMUX_BIN='/usr/local/bin/tmux'
JOB_ID=''

# Convert time shorthand (e.g. 8h, 30m, 2d, 1d12h, 1h30m) to HH:MM:SS
function parse_time {
  local input="$1"

  # Already in SLURM format (contains : or D-), pass through
  if [[ "$input" =~ [:] ]] || [[ "$input" =~ ^[0-9]+- ]]; then
    echo "$input"
    return
  fi

  # Pure integer = minutes (SLURM native)
  if [[ "$input" =~ ^[0-9]+$ ]]; then
    echo "$input"
    return
  fi

  local days=0 hours=0 minutes=0
  local remaining="$input"

  if [[ "$remaining" =~ ^([0-9]+)d ]]; then
    days="${BASH_REMATCH[1]}"
    remaining="${remaining#*d}"
  fi
  if [[ "$remaining" =~ ^([0-9]+)h ]]; then
    hours="${BASH_REMATCH[1]}"
    remaining="${remaining#*h}"
  fi
  if [[ "$remaining" =~ ^([0-9]+)m ]]; then
    minutes="${BASH_REMATCH[1]}"
    remaining="${remaining#*m}"
  fi

  if [[ -n "$remaining" ]]; then
    echo 1>&2 "Warning: unrecognized time format '$input', passing through to SLURM"
    echo "$input"
    return
  fi

  # Normalize carries so e.g. 90m -> 1h30m and 25h -> 1d1h, keeping each
  # field within range for SLURM's [D-]HH:MM:SS format.
  hours=$((hours + minutes / 60))
  minutes=$((minutes % 60))
  days=$((days + hours / 24))
  hours=$((hours % 24))

  if ((days > 0)); then
    printf '%d-%02d:%02d:00\n' "$days" "$hours" "$minutes"
  else
    printf '%02d:%02d:00\n' "$hours" "$minutes"
  fi
}

function usage {
  cat <<EOF
Usage: sinteractive [OPTIONS] [-- SBATCH_ARGS...]
       sinteractive --attach JOBID|NAME

Start an interactive tmux session on a compute node via Slurm.

Options:
  -n, --name NAME       Tag the session with a name for easy reattach
                        (allowed: letters, digits, '.', '_', '-')
  --node NODE           Request a specific compute node (e.g., compute01)
  --partition PART      Slurm partition (default: interactive)
  --time TIME           Wall time limit (default: 1 day)
                        Supports shorthand: 8h, 30m, 2d, 1d12h, 1h30m
  -j, --threads N       Number of CPUs (alias for --cpus-per-task)
  -m SIZE               Memory (alias for --mem, e.g., 16G)
  -a, --attach TARGET   Reattach to a running session by JOBID or NAME
  -l, --list            List running sinteractive sessions (with NAME and CWD)
  -h, --help            Show this help message

Note: -n is consumed by sinteractive as --name. Use --ntasks=N to set
sbatch ntasks instead of -n.

All other options are passed directly to sbatch. Examples:

  sinteractive                          # 1-day session, 2 CPUs, 8G memory
  sinteractive -n myproj                # named session
  sinteractive --node compute01         # run on a specific node
  sinteractive --time=2h -p rna          # 2h session on rna partition
  sinteractive --mem=16G --cpus-per-task=4

Reconnecting after a disconnect:

  If your SSH connection drops or you detach (Ctrl-b d), the tmux
  session keeps running. To reconnect from the login node:

  sinteractive --attach JOBID           # reattach by job id
  sinteractive --attach myproj          # reattach by name

  Use "sinteractive --list" to find your running sessions.

Timeout warning:

  A warning appears in the tmux status bar 10 minutes before the time
  limit. The bar turns yellow to alert you to save your work.
EOF
  exit 0
}

function main {
  if [[ "${1:-}" == 'tmux' ]]; then
    shift
    start_tmux "$@"
    return
  elif [[ "${1:-}" == 'attach' ]]; then
    shift
    attach_tmux "$@"
    return
  fi

  # Don't allow launching sinteractive from inside an existing session
  if [[ -n "${TMUX:-}" ]] && [[ "$TMUX" == *sinteractive* ]]; then
    echo 1>&2 "Error: Already inside an sinteractive session. Exit this session first."
    exit 1
  fi

  # Parse custom flags before passing remaining args to sbatch
  local args=()
  local reattach_target=''
  local session_name=''
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      usage
      ;;
    -l | --list)
      list_sessions
      ;;
    -a | --attach)
      if [[ -z "${2:-}" || "$2" == -* ]]; then
        echo 1>&2 "Error: $1 requires a JOBID or NAME argument."
        echo 1>&2 "Run 'sinteractive --list' to see available sessions."
        exit 1
      fi
      reattach_target="$2"
      shift 2
      ;;
    --attach=*)
      reattach_target="${1#--attach=}"
      if [[ -z "${reattach_target}" ]]; then
        echo 1>&2 "Error: --attach requires a JOBID or NAME argument."
        echo 1>&2 "Run 'sinteractive --list' to see available sessions."
        exit 1
      fi
      shift
      ;;
    -n | --name)
      [[ $# -ge 2 ]] || { echo 1>&2 "Error: $1 requires a NAME argument."; exit 1; }
      session_name="$2"
      shift 2
      ;;
    --name=*)
      session_name="${1#--name=}"
      shift
      ;;
    --node)
      [[ $# -ge 2 ]] || { echo 1>&2 "Error: --node requires a NODE argument."; exit 1; }
      args+=(--nodelist="$2")
      shift 2
      ;;
    --node=*)
      args+=(--nodelist="${1#--node=}")
      shift
      ;;
    --time)
      [[ $# -ge 2 ]] || { echo 1>&2 "Error: --time requires a TIME argument."; exit 1; }
      args+=(--time="$(parse_time "$2")")
      shift 2
      ;;
    --time=*)
      args+=(--time="$(parse_time "${1#--time=}")")
      shift
      ;;
    -t)
      [[ $# -ge 2 ]] || { echo 1>&2 "Error: -t requires a TIME argument."; exit 1; }
      args+=(-t "$(parse_time "$2")")
      shift 2
      ;;
    --partition)
      [[ $# -ge 2 ]] || { echo 1>&2 "Error: --partition requires a PARTITION argument."; exit 1; }
      args+=(--partition="$2")
      shift 2
      ;;
    --partition=*)
      args+=(--partition="${1#--partition=}")
      shift
      ;;
    -j | --threads)
      [[ $# -ge 2 ]] || { echo 1>&2 "Error: $1 requires a CPU-count argument."; exit 1; }
      args+=(--cpus-per-task="$2")
      shift 2
      ;;
    --threads=*)
      args+=(--cpus-per-task="${1#--threads=}")
      shift
      ;;
    -m)
      [[ $# -ge 2 ]] || { echo 1>&2 "Error: -m requires a SIZE argument."; exit 1; }
      args+=(--mem="$2")
      shift 2
      ;;
    *)
      args+=("$1")
      shift
      ;;
    esac
  done

  if [[ -n "${reattach_target}" ]]; then
    reattach "${reattach_target}"
  fi

  if [[ -n "${session_name}" ]]; then
    if ! [[ "${session_name}" =~ ^[A-Za-z0-9._-]+$ ]]; then
      echo 1>&2 "Error: --name must contain only letters, digits, '.', '_', '-'"
      exit 1
    fi
    # Best-effort duplicate-name guard: the Comment marker that records the
    # name is only set after submission (see below), so two near-simultaneous
    # launches with the same name can both pass here. Reattach-by-name
    # resolves the resulting ambiguity by erroring on multiple matches.
    local existing
    existing=$(squeue --me --states RUNNING,PENDING --noheader \
      --Format=JobID:12,Comment:80 2>/dev/null |
      awk -v n="sinteractive:${session_name}" '$2 == n {print $1}')
    if [[ -n "${existing}" ]]; then
      echo 1>&2 "Error: A sinteractive session named '${session_name}' is already running:"
      echo 1>&2 "  JobID(s): $(echo ${existing} | xargs)"
      echo 1>&2 "Pick a different name, or reattach with: sinteractive --attach ${session_name}"
      exit 1
    fi
  fi

  set -- "${args[@]}"

  # If a session name was given and the user did not pass --job-name/-J,
  # set it so the name shows up natively in squeue output.
  if [[ -n "${session_name}" ]] && ! printf '%s\n' "$@" | grep -qE '^(--job-name|-J)'; then
    set -- --job-name="sint-${session_name}" "$@"
  fi

  # Default to 1 day if no --time/-t specified
  if ! printf '%s\n' "$@" | grep -qE '^(--time|-t)'; then
    set -- --time=24:00:00 "$@"
  fi

  # Default to interactive partition if no --partition/-p specified
  if ! printf '%s\n' "$@" | grep -qE '^(--partition|-p)'; then
    set -- --partition=interactive "$@"
  fi

  # Default to 2 CPUs if no --cpus-per-task/-c specified
  if ! printf '%s\n' "$@" | grep -qE '^(--cpus-per-task|-c)'; then
    set -- --cpus-per-task=2 "$@"
  fi

  # Default to 8G memory if no --mem specified
  if ! printf '%s\n' "$@" | grep -qE '^--mem'; then
    set -- --mem=8G "$@"
  fi

  # Send warning signal 10 minutes before time limit
  if ! printf '%s\n' "$@" | grep -qE '^--signal'; then
    set -- --signal=B:USR1@600 "$@"
  fi

  # Refuse to submit if --time would overlap an upcoming MAINT reservation
  if ! check_maintenance_window "$@"; then
    exit 1
  fi

  # Check interactive job limit before submitting
  local partition
  partition=$(get_partition_from_args "$@")

  if ! check_job_limit "$partition"; then
    exit 1
  fi

  local output
  local sbatch_ec
  output=$(sbatch --output=/dev/null --error=/dev/null "$@" "${BASH_SOURCE[0]}" tmux)
  sbatch_ec=$?

  JOB_ID=$(grep -Eo -e '\b[0-9]+$' <<<"${output}")
  if [[ -z "${JOB_ID}" ]]; then
    echo 1>&2 "$0: unable to find job id in sbatch output"
    exit "$sbatch_ec"
  fi

  local job_comment="sinteractive"
  if [[ -n "${session_name}" ]]; then
    job_comment="sinteractive:${session_name}"
  fi
  scontrol update JobId="${JOB_ID}" Comment="${job_comment}"

  echo 1>&2 "Interactive job with ID ${JOB_ID} submitted, please wait."
  local state
  while true; do
    sleep 5s

    # Check job status
    state=$(squeue --jobs "${JOB_ID}" --states PENDING,RUNNING --noheader --Format state | xargs)
    if [[ "${state}" == 'RUNNING' ]]; then
      break
    elif [[ "${state}" != 'PENDING' ]]; then
      echo 1>&2 "$0: job is neither RUNNING nor PENDING. Aborting."
      scancel --quiet "${JOB_ID}"
      exit 1
    fi

    echo 1>&2 -n '.'
  done

  local batchhost
  batchhost=$(squeue --jobs "${JOB_ID}" --noheader --Format batchhost | xargs)

  echo 1>&2 ''
  echo 1>&2 'Connecting to sinteractive session, please wait...'

  # A RUNNING job only means the allocation exists; the batch script still
  # has to bring up the tmux server. Poll for the session (a single SSH that
  # retries on the node) instead of guessing a fixed sleep, which races on a
  # slow or loaded node.
  local sock="sinteractive-${JOB_ID}"
  local connected=0
  if ssh -o BatchMode=yes -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new \
    "${batchhost}" \
    "for i in \$(seq 1 30); do ${TMUX_BIN} -L '${sock}' has-session -t '${sock}' 2>/dev/null && exit 0; sleep 1; done; exit 1"; then
    connected=1
  fi

  # The session is up (or we gave up waiting); from this point a detach or
  # disconnect should NOT cancel the job.
  trap - SIGINT SIGTERM EXIT

  if ((connected == 0)); then
    echo 1>&2 ''
    echo 1>&2 "$0: tmux session did not come up on ${batchhost} within 30s."
    echo 1>&2 "Job ${JOB_ID} may still be starting. Reconnect with:"
    echo 1>&2 "  sinteractive --attach ${JOB_ID}"
    exit 1
  fi

  ssh -X -t "${batchhost}" "${BASH_SOURCE[0]}" attach "sinteractive-${JOB_ID}"

  # Give the batch script a moment to finish shutting down
  sleep 3

  # Check if the sinteractive job is still running after SSH exits
  local post_state
  post_state=$(squeue --jobs "${JOB_ID}" --states RUNNING --noheader --Format state 2>/dev/null | xargs)

  if [[ "${post_state}" == 'RUNNING' ]]; then
    echo 1>&2 ''
    echo 1>&2 "Disconnected from sinteractive session."
    echo 1>&2 "Your job ${JOB_ID} is still running on ${batchhost}."
    echo 1>&2 ''
    local attach_target="${JOB_ID}"
    if [[ -n "${session_name}" ]]; then
      attach_target="${session_name}"
    fi
    echo 1>&2 "To reconnect:"
    echo 1>&2 "  sinteractive --attach ${attach_target}"
    echo 1>&2 ''
    echo 1>&2 "To cancel the job:"
    echo 1>&2 "  scancel ${JOB_ID}"

    # Show other running sinteractive sessions
    local other_running
    other_running=$(squeue --me --states RUNNING --noheader \
      --Format=JobID:12,Comment:30,NodeList:16,TimeUsed:12,TimeLimit:12 2>/dev/null |
      grep sinteractive | grep -v "^${JOB_ID} ")

    if [[ -n "$other_running" ]]; then
      echo 1>&2 ''
      echo 1>&2 'Other running sinteractive sessions:'
      printf 1>&2 '  %-10s  %-14s  %-10s  %-10s\n' 'JOBID' 'NODE' 'ELAPSED' 'TIMELIMIT'
      while read -r jobid comment node elapsed limit; do
        printf 1>&2 '  %-10s  %-14s  %-10s  %-10s\n' "$jobid" "$node" "$elapsed" "$limit"
      done <<<"$other_running"
    fi
  else
    echo 1>&2 "Session ended. Job ${JOB_ID} is no longer running."

    # Show any remaining sinteractive sessions
    local remaining
    remaining=$(squeue --me --states RUNNING --noheader \
      --Format=JobID:12,Comment:30,NodeList:16,TimeUsed:12,TimeLimit:12 2>/dev/null |
      grep sinteractive)

    if [[ -n "$remaining" ]]; then
      echo 1>&2 ''
      echo 1>&2 'You have other sinteractive sessions still running:'
      printf 1>&2 '  %-10s  %-14s  %-10s  %-10s\n' 'JOBID' 'NODE' 'ELAPSED' 'TIMELIMIT'
      while read -r jobid comment node elapsed limit; do
        printf 1>&2 '  %-10s  %-14s  %-10s  %-10s\n' "$jobid" "$node" "$elapsed" "$limit"
      done <<<"$remaining"
      echo 1>&2 ''
      echo 1>&2 'To free slots, cancel sessions you no longer need:'
      while read -r jobid _rest; do
        echo 1>&2 "  scancel $jobid"
      done <<<"$remaining"
    fi
  fi
}

# Query the current working directory of an sinteractive tmux session by
# asking tmux on the compute node. Returns empty string on failure.
function get_session_cwd {
  local node=$1 jobid=$2
  local sock="sinteractive-${jobid}"
  local session="sinteractive-${jobid}"
  local cwd
  cwd=$(ssh -o BatchMode=yes -o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new \
    "$node" \
    "$TMUX_BIN -L '$sock' display-message -p -t '$session' '#{pane_current_path}'" \
    2>/dev/null)
  # Collapse $HOME prefix to ~ for readability
  if [[ -n "$cwd" && "$cwd" == "$HOME"* ]]; then
    cwd="~${cwd#$HOME}"
  fi
  printf '%s' "$cwd"
}

function list_sessions {
  local lines
  lines=$(squeue --me --states RUNNING --noheader \
    --Format=JobID:12,Comment:80,NodeList:16,TimeUsed:12,TimeLimit:12 |
    grep -E '[[:space:]]sinteractive([:-]|[[:space:]]|$)')

  if [[ -z "$lines" ]]; then
    echo "No running sinteractive sessions."
    exit 0
  fi

  # Query cwd for each session in parallel; results land in $tmpdir/<jobid>
  local tmpdir
  tmpdir=$(mktemp -d)
  trap 'rm -rf "$tmpdir"' EXIT
  while read -r jobid comment node elapsed limit; do
    (get_session_cwd "$node" "$jobid" >"$tmpdir/$jobid") &
  done <<<"$lines"
  wait

  printf '%-10s  %-20s  %-14s  %-10s  %-10s  %s\n' \
    'JOBID' 'NAME' 'NODE' 'ELAPSED' 'TIMELIMIT' 'CWD'
  while read -r jobid comment node elapsed limit; do
    local name='-'
    if [[ "$comment" =~ ^sinteractive:(.+)$ ]]; then
      name="${BASH_REMATCH[1]}"
    fi
    local cwd
    cwd=$(<"$tmpdir/$jobid")
    [[ -z "$cwd" ]] && cwd='-'
    printf '%-10s  %-20s  %-14s  %-10s  %-10s  %s\n' \
      "$jobid" "$name" "$node" "$elapsed" "$limit" "$cwd"
  done <<<"$lines"

  echo ''
  echo 'To reattach:  sinteractive --attach JOBID  (or NAME if set)'
  exit 0
}

# Extract the effective partition name from the processed argument list.
function get_partition_from_args {
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --partition=*)
      echo "${1#--partition=}"
      return
      ;;
    -p)
      echo "${2:-}"
      return
      ;;
    *)
      shift
      ;;
    esac
  done
  echo "interactive"
}

# Extract the effective --time / -t value from the processed argument list.
# Echoes the value (e.g. "24:00:00", "1-12:00:00", "120") and returns 0; if
# no time is set, returns 1.
function extract_time_from_args {
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --time=*)
      echo "${1#--time=}"
      return 0
      ;;
    --time)
      echo "${2:-}"
      return 0
      ;;
    -t)
      echo "${2:-}"
      return 0
      ;;
    -t=*)
      echo "${1#-t=}"
      return 0
      ;;
    *)
      shift
      ;;
    esac
  done
  return 1
}

# Convert a SLURM time string to whole seconds. Echoes the integer and returns
# 0 on success; returns 1 if the format isn't recognized (caller should fail
# open).
function slurm_time_to_seconds {
  local t=$1
  local d=0 h=0 m=0 s=0
  if [[ "$t" =~ ^([0-9]+)-([0-9]+):([0-9]+):([0-9]+)$ ]]; then
    d=${BASH_REMATCH[1]}; h=${BASH_REMATCH[2]}; m=${BASH_REMATCH[3]}; s=${BASH_REMATCH[4]}
  elif [[ "$t" =~ ^([0-9]+)-([0-9]+):([0-9]+)$ ]]; then
    d=${BASH_REMATCH[1]}; h=${BASH_REMATCH[2]}; m=${BASH_REMATCH[3]}
  elif [[ "$t" =~ ^([0-9]+)-([0-9]+)$ ]]; then
    d=${BASH_REMATCH[1]}; h=${BASH_REMATCH[2]}
  elif [[ "$t" =~ ^([0-9]+):([0-9]+):([0-9]+)$ ]]; then
    h=${BASH_REMATCH[1]}; m=${BASH_REMATCH[2]}; s=${BASH_REMATCH[3]}
  elif [[ "$t" =~ ^([0-9]+):([0-9]+)$ ]]; then
    m=${BASH_REMATCH[1]}; s=${BASH_REMATCH[2]}
  elif [[ "$t" =~ ^([0-9]+)$ ]]; then
    m=${BASH_REMATCH[1]}
  else
    return 1
  fi
  echo $(( d * 86400 + 10#$h * 3600 + 10#$m * 60 + 10#$s ))
}

# Format seconds as a short human duration like "1d 2h 5m" or "45m".
function format_short_duration {
  local secs=$1
  local d=$(( secs / 86400 ))
  local h=$(( (secs % 86400) / 3600 ))
  local m=$(( (secs % 3600) / 60 ))
  local out=""
  (( d > 0 )) && out+="${d}d "
  (( h > 0 )) && out+="${h}h "
  if (( m > 0 )) || (( d == 0 && h == 0 )); then
    out+="${m}m"
  fi
  echo "${out% }"
}

# Refuse to submit if the requested --time would overlap an upcoming MAINT
# reservation. Returns 0 to proceed, 1 to abort. Fails open silently when
# scontrol is unavailable, no MAINT reservation is queued, or the time string
# can't be parsed (the scheduler will still apply its own constraints).
function check_maintenance_window {
  # User explicitly opted into a reservation — trust them
  local arg
  for arg in "$@"; do
    case "$arg" in
    --reservation=*|--reservation) return 0 ;;
    esac
  done

  local resv_out
  resv_out=$(scontrol show reservation -o 2>/dev/null) || return 0
  [[ -z "$resv_out" ]] && return 0
  [[ "$resv_out" == "No reservations"* ]] && return 0

  local now_epoch best_epoch=0 best_name=""
  now_epoch=$(date +%s)

  local line start_str start_epoch
  while IFS= read -r line; do
    [[ "$line" =~ Flags=[^[:space:]]*MAINT ]] || continue
    [[ "$line" =~ StartTime=([^[:space:]]+) ]] || continue
    start_str=${BASH_REMATCH[1]}
    start_epoch=$(date -d "$start_str" +%s 2>/dev/null) || continue
    (( start_epoch > now_epoch )) || continue
    if (( best_epoch == 0 || start_epoch < best_epoch )); then
      best_epoch=$start_epoch
      if [[ "$line" =~ ReservationName=([^[:space:]]+) ]]; then
        best_name=${BASH_REMATCH[1]}
      fi
    fi
  done <<<"$resv_out"

  (( best_epoch == 0 )) && return 0

  local time_str time_secs
  time_str=$(extract_time_from_args "$@") || return 0
  time_secs=$(slurm_time_to_seconds "$time_str") || return 0

  local job_end=$(( now_epoch + time_secs ))
  (( job_end <= best_epoch )) && return 0

  local gap_secs=$(( best_epoch - now_epoch ))
  local overlap_secs=$(( job_end - best_epoch ))
  local fit_secs=$(( gap_secs - 300 ))

  local maint_when end_when
  maint_when=$(date -d "@$best_epoch" "+%a %b %-d %H:%M")
  end_when=$(date -d "@$job_end" "+%a %b %-d %H:%M")

  local suggestion=""
  if (( fit_secs >= 3600 )); then
    suggestion="sinteractive --time=$(( fit_secs / 3600 ))h"
  elif (( fit_secs >= 60 )); then
    suggestion="sinteractive --time=$(( fit_secs / 60 ))m"
  fi

  echo 1>&2 ""
  echo 1>&2 "Error: --time=${time_str} conflicts with scheduled maintenance."
  echo 1>&2 ""
  echo 1>&2 "  Reservation: ${best_name:-<unnamed>}"
  echo 1>&2 "  Starts:      ${maint_when} (in $(format_short_duration $gap_secs))"
  echo 1>&2 "  Job would end: ${end_when} ($(format_short_duration $overlap_secs) past start)"
  echo 1>&2 ""
  if [[ -n "$suggestion" ]]; then
    echo 1>&2 "Slurm won't schedule this job until after the reservation ends. To start"
    echo 1>&2 "a session now, shorten --time to fit before maintenance:"
    echo 1>&2 ""
    echo 1>&2 "  ${suggestion}"
  else
    echo 1>&2 "The window before maintenance is too short for a useful session."
    echo 1>&2 "Wait until after the reservation ends."
  fi
  echo 1>&2 ""
  echo 1>&2 "See 'scontrol show reservation' for full details."
  echo 1>&2 ""
  return 1
}

# Check if submitting another job would exceed the QOS MaxJobsPerUser limit.
# Only checks when targeting the interactive partition.
# Falls through silently if sacctmgr or squeue are unavailable.
function check_job_limit {
  local partition="$1"

  # Only enforce for the interactive partition
  if [[ "$partition" != "interactive" ]]; then
    return 0
  fi

  # Query QOS limit dynamically; fail open if sacctmgr unavailable
  local max_jobs
  max_jobs=$(sacctmgr show qos interactive format=MaxJobsPerUser --noheader --parsable2 2>/dev/null)
  if [[ $? -ne 0 ]] || [[ -z "$max_jobs" ]]; then
    return 0
  fi

  max_jobs=$(echo "$max_jobs" | xargs)

  if ! [[ "$max_jobs" =~ ^[0-9]+$ ]]; then
    return 0
  fi

  # Count current running + pending jobs on the interactive partition
  local current_jobs
  current_jobs=$(squeue --me --partition=interactive --states=RUNNING,PENDING --noheader 2>/dev/null | wc -l)
  if [[ $? -ne 0 ]]; then
    return 0
  fi

  current_jobs=$(echo "$current_jobs" | xargs)

  if ((current_jobs >= max_jobs)); then
    echo 1>&2 ""
    echo 1>&2 "Error: You already have ${current_jobs}/${max_jobs} interactive jobs (the maximum allowed)."
    echo 1>&2 ""

    local lines
    lines=$(squeue --me --partition=interactive --states=RUNNING,PENDING --noheader \
      --Format=JobID:12,Name:20,NodeList:16,State:10,TimeUsed:12,TimeLimit:12 2>/dev/null)

    if [[ -n "$lines" ]]; then
      echo 1>&2 "Your current interactive jobs:"
      echo 1>&2 ""
      printf 1>&2 '  %-10s  %-18s  %-14s  %-9s  %-10s  %-10s\n' \
        'JOBID' 'NAME' 'NODE' 'STATE' 'ELAPSED' 'TIMELIMIT'
      while IFS= read -r line; do
        read -r jobid name node state elapsed limit <<<"$line"
        printf 1>&2 '  %-10s  %-18s  %-14s  %-9s  %-10s  %-10s\n' \
          "$jobid" "$name" "$node" "$state" "$elapsed" "$limit"
      done <<<"$lines"
      echo 1>&2 ""
    fi

    echo 1>&2 "To reattach to an existing session:"
    local jobids
    jobids=$(squeue --me --partition=interactive --states=RUNNING --noheader --Format=JobID 2>/dev/null | xargs)
    for jid in $jobids; do
      echo 1>&2 "  sinteractive --attach $jid"
    done
    echo 1>&2 ""
    echo 1>&2 "To free a slot, cancel a session:"
    jobids=$(squeue --me --partition=interactive --states=RUNNING,PENDING --noheader --Format=JobID 2>/dev/null | xargs)
    for jid in $jobids; do
      echo 1>&2 "  scancel $jid"
    done
    echo 1>&2 ""
    return 1
  fi

  return 0
}

function reattach {
  local target=$1
  local jobid

  if [[ "${target}" =~ ^[0-9]+$ ]]; then
    jobid="${target}"
  else
    # Resolve by name via the Comment marker set at submit time
    local matches
    matches=$(squeue --me --states RUNNING --noheader \
      --Format=JobID:12,Comment:80 2>/dev/null |
      awk -v n="sinteractive:${target}" '$2 == n {print $1}')
    local count
    count=$(printf '%s\n' "${matches}" | grep -c .)
    if [[ "${count}" -eq 0 ]]; then
      echo 1>&2 "$0: no running sinteractive session named '${target}'"
      echo 1>&2 "Run 'sinteractive --list' to see available sessions."
      exit 1
    elif [[ "${count}" -gt 1 ]]; then
      echo 1>&2 "$0: multiple running sessions named '${target}':"
      echo 1>&2 "  $(echo ${matches} | xargs)"
      echo 1>&2 "Reattach by JOBID instead."
      exit 1
    fi
    jobid="${matches}"
  fi

  local sock="sinteractive-${jobid}"

  # Verify the job is still running
  local state
  state=$(squeue --jobs "${jobid}" --states RUNNING --noheader --Format state 2>/dev/null | xargs)
  if [[ "${state}" != 'RUNNING' ]]; then
    echo 1>&2 "$0: job ${jobid} is not running (state: ${state:-unknown})"
    exit 1
  fi

  echo 1>&2 "Reattaching to sinteractive session ${jobid}..."
  exec srun --overlap --jobid="${jobid}" --pty \
    $TMUX_BIN -L "$sock" -u attach-session -t "sinteractive-${jobid}"
}

function warn_timeout {
  local session_name="$1"
  local sock="sinteractive-${SLURM_JOB_ID}"

  # Get job end time (epoch seconds) for countdown
  local end_epoch
  end_epoch=$(squeue --jobs "${SLURM_JOB_ID}" --noheader --Format EndTime | xargs)
  end_epoch=$(date -d "$end_epoch" +%s 2>/dev/null)

  # Warning banner at top of pane, regular status bar stays at bottom
  $TMUX_BIN -L "$sock" set-option -t "$session_name" pane-border-status top

  # Countdown loop: alternates colors every second for blink effect
  while $TMUX_BIN -L "$sock" has-session -t "$session_name" 2>/dev/null; do
    local remaining=$((end_epoch - $(date +%s)))
    if ((remaining < 0)); then remaining=0; fi
    local mins=$((remaining / 60))
    local secs=$((remaining % 60))
    local msg
    printf -v msg 'SESSION ENDS IN %d:%02d -- SAVE YOUR WORK' "$mins" "$secs"

    $TMUX_BIN -L "$sock" set-option -t "$session_name" pane-border-format \
      "#[align=centre,fg=black,bg=yellow,bold,fill=yellow] >>> $msg <<< "
    sleep 1
    $TMUX_BIN -L "$sock" set-option -t "$session_name" pane-border-format \
      "#[align=centre,fg=yellow,bg=red,bold,fill=red] >>> $msg <<< "
    sleep 1
  done &
}

function start_tmux {
  export TERM=xterm-256color

  local session_name="sinteractive-${SLURM_JOB_ID}"
  local wait_channel="sinteractive-done-${SLURM_JOB_ID}"
  local sock="sinteractive-${SLURM_JOB_ID}"

  # Each job gets its own tmux server socket (-L) so that SLURM cgroup
  # cleanup for one job does not kill the tmux server shared by others.
  $TMUX_BIN -L "$sock" -u new-session -d -s "$session_name"

  # 50k lines of scrollback (default 2000)
  $TMUX_BIN -L "$sock" set-option -t "$session_name" history-limit 50000
  # OSC 52 clipboard integration (copy works over SSH)
  $TMUX_BIN -L "$sock" set-option -t "$session_name" set-clipboard on
  # Keep panes open on non-zero exit for debugging (tmux >= 3.4)
  $TMUX_BIN -L "$sock" set-option -t "$session_name" remain-on-exit failed
  # Auto-respawn pane on Ctrl-C / SIGINT (exit 130) instead of "Pane is dead"
  $TMUX_BIN -L "$sock" set-hook -t "$session_name" pane-died \
    "if -F '#{==:#{pane_dead_status},130}' 'respawn-pane -k'"
  # Highlight windows with new activity
  $TMUX_BIN -L "$sock" set-option -t "$session_name" monitor-activity on
  # Auto-rename windows to current command
  $TMUX_BIN -L "$sock" set-option -t "$session_name" automatic-rename on

  # Strip SLURM vars from tmux session so child processes (e.g. snakemake)
  # don't think they're running as a SLURM job step.
  # set-environment -u prevents future panes from inheriting the vars;
  # send-keys unsets them in the already-running initial shell.
  for var in $(env | grep ^SLURM_ | cut -d= -f1); do
      $TMUX_BIN -L "$sock" set-environment -t "$session_name" -u "$var"
  done
  $TMUX_BIN -L "$sock" send-keys -t "$session_name" \
      ' unset ${!SLURM_@}; clear' Enter

  # Status bar: left = job info, right = help/instructions
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-interval 60
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-left \
    "#[bold] interactive @ #{host_short} | %I:%M %p "
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-left-length 50
  # Hide the window list (0:bash*) from the center of the status bar
  $TMUX_BIN -L "$sock" set-option -t "$session_name" window-status-format ''
  $TMUX_BIN -L "$sock" set-option -t "$session_name" window-status-current-format ''
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-right \
    "#[fg=black,bg=colour229,bold] Detach: Ctrl+b d | Reattach: sinteractive --attach ${SLURM_JOB_ID} | Docs: https://tinyurl.com/2s45khbx "
  $TMUX_BIN -L "$sock" set-option -t "$session_name" status-right-length 120

  $TMUX_BIN -L "$sock" set-hook -t "$session_name" session-closed \
    "run-shell '$TMUX_BIN -L $sock wait-for -S $wait_channel'"

  # Trap SIGUSR1 sent by SLURM 10 minutes before time limit
  trap 'warn_timeout "$session_name"' USR1

  # Run wait-for in background; `wait` builtin (foreground) is interruptible
  # by signals, unlike external commands which block trap delivery in bash.
  $TMUX_BIN -L "$sock" wait-for "$wait_channel" &
  local wait_pid=$!
  while true; do
    wait $wait_pid
    # 0 or 1-128 = process exited; >128 = signal interrupted wait
    if (($? <= 128)); then
      break
    fi
  done

  trap - USR1
}

function attach_tmux {
  local SESSION=$1
  local sock="$SESSION"

  if [[ "${DISPLAY:-}" != '' ]]; then
    $TMUX_BIN -L "$sock" setenv -t "$SESSION" DISPLAY "$DISPLAY"
  fi

  exec $TMUX_BIN -L "$sock" -u attach-session -t "$SESSION"
}

function cleanup {
  if [[ -n "${JOB_ID}" ]]; then
    scancel --quiet "${JOB_ID}"
  fi

  exit
}

trap cleanup SIGINT SIGTERM EXIT

main "$@"
